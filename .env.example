# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Frontend (set in Vercel dashboard for prod, leave empty for local dev)
# VITE_API_URL=https://your-app.railway.app

# Redis
# Local dev: redis://localhost:6379
# Upstash:   rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# AWS S3 (created by CDK stack in /infra)
# No access keys needed — EC2 IAM role handles auth automatically
# In prod these come from SSM Parameter Store via scripts/start.sh
S3_BUCKET=vanishdrop-uploads-123456789012
S3_REGION=us-east-1

# Optional: dedicated bucket for real infrastructure tests.
# When set, `npm run test:infra` / `npm run verify:full` use this bucket instead of S3_BUCKET.
S3_TEST_BUCKET=vanishdrop-test-uploads-123456789012
S3_TEST_REGION=us-east-1

# Limits
MAX_FILE_SIZE=10737418240
UPLOAD_RATE_LIMIT=10
SESSION_GRACE_PERIOD=30
PRESIGNED_URL_EXPIRY=3600
DOWNLOAD_URL_EXPIRY=300
